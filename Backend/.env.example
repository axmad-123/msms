# Railway → your API service → Variables
# Add PostgreSQL plugin first; Railway sets DATABASE_URL automatically.

ASPNETCORE_ENVIRONMENT=Production

# Optional if not using Railway PostgreSQL plugin:
# ConnectionStrings__DefaultConnection=Host=...;Port=5432;Database=...;Username=...;Password=...;SSL Mode=Require;Trust Server Certificate=true

Jwt__Issuer=MSMS
Jwt__Audience=MSMS
Jwt__SigningKey=change-me-to-at-least-32-random-characters!!
Jwt__AccessTokenMinutes=120
Jwt__RefreshTokenDays=14

# After Vercel deploy, paste your frontend URL (no trailing slash):
CORS_ORIGINS=https://your-app.vercel.app

Cloudinary__CloudName=your_cloud_name
Cloudinary__ApiKey=your_api_key
Cloudinary__ApiSecret=your_api_secret
Cloudinary__Folder=msms/students

Seed__DemoData=true
Seed__ForceReseed=false
Seed__DemoPassword=Demo@12345

EnableSwagger=true
